
@{
    ViewData["Title"] = "Index";
}

@* <h1>Index</h1> *@
@model List<LibrarySystem.Models.Book>

<h2>Book List</h2>

<table border="1">

    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Author</th>
    </tr>

    @foreach (var book in Model)
    {
        <tr>
            <td>@book.Id</td>
            <td>@book.Title</td>
            <td>@book.Author</td>
        </tr>
    }

</table>

